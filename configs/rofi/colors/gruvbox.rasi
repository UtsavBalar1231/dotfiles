* {
  bg0:      #141617b6;
  bg1:      #3c3836e6;
  bg2:      #504945e6;
  bg3:      #665c54e6;
  bg4:      #7c6f64e6;

  fg0:      #fbf1c7;
  fg1:      #ebdbb2;
  fg2:      #d5c4a1;
  fg3:      #bdae93;
  fg4:      #a89984;

  red:      #cc241d;
  green:    #98971a;
  yellow:   #d79921;
  blue:     #458588;
  purple:   #b16286;
  aqua:     #689d6a;
  orange:   #d65d0e;
  gray:     #928374;
 
  accent:   #ebdbb2e6;

  background-color: transparent;
  text-color:       @fg0;
}
