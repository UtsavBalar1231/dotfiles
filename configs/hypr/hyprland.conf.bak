source = ~/.config/hypr/conf/themes/gruvbox.conf

source = ~/.config/hypr/conf/environment.conf
source = ~/.config/hypr/conf/startup.conf
source = ~/.config/hypr/conf/settings.conf
monitor= , highrr, auto, 1
# source = ~/.config/hypr/conf/monitors.conf
source = ~/.config/hypr/conf/windowrules.conf

# Animation configs - uncomment only ONE of these at a time:
source = ~/.config/hypr/conf/animations.conf       # Default macOS-like animations
# source = ~/.config/hypr/conf/animations_minimal.conf  # Ultra-fast minimal animations
# source = ~/.config/hypr/conf/animations_fluid.conf    # Smooth fluid animations
# source = ~/.config/hypr/conf/animations_subtle.conf   # Subtle, barely visible animations
# source = ~/.config/hypr/conf/animations_dynamic.conf  # Dynamic animations with bounce effects

source = ~/.config/hypr/conf/plugins.conf
source = ~/.config/hypr/conf/keybinds.conf

